{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FitGirl Downloader",
  "version": "0.3.0",
  "identifier": "com.siarh.fitgirl-downloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FitGirl Downloader",
        "width": 900,
        "height": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
